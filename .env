NEXT_PUBLIC_API_URL=http://151.185.47.67:5001/api/v1

# ── EasyHMS public API (patient booking portal) ──────────────────────────────
# Root of the EasyHMS API (NO trailing slash, NO /api prefix — paths are off root).
# Points at the dev deployment (develop branch -> Dev VM, port 5001 per
# easyHMSAPI/.github/workflows/deploy-api.yml) instead of localhost, so local dev
# and the deployed dev container both exercise the real backend.
EASYHMS_API_BASE_URL=http://151.185.45.77:5001
# Optional — the public API doesn't require a key, so this can stay blank for local/dev use.
# Only set it if this deployment's traffic should be identified/revocable separately from
# anonymous callers, via easyHMSAPI's tools/IssuePublicApiKey console tool (see
# easyHMSAPI/docs/OPS-ISSUE-PUBLIC-API-KEY.md). Keep server-side only — do NOT prefix with
# NEXT_PUBLIC. For production, move it out of this committed file into .env.local or a secret store.
EASYHMS_API_KEY=
# Header the API expects the key in. Adjust to match the backend (e.g. X-Api-Key).
EASYHMS_API_KEY_HEADER=X-Api-Key

# ── AI-assisted doctor search (app/api/search/parse) ─────────────────────────
# Optional — powers the "type/speak anything about symptoms" search fallback. Leave blank
# to disable — search just stays literal-keyword-only. Keep server-side only.
ANTHROPIC_API_KEY=
