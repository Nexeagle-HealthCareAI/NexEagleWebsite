# Origin of the CMS API that powers the live-chat SignalR hub (<origin>/chathub).
# Must be NEXT_PUBLIC_-prefixed — Next.js only inlines NEXT_PUBLIC_* vars into the
# browser bundle, and this is read client-side. Baked in at build time (next build
# auto-loads .env.production), so it must be correct before building, not just at
# container start.
#   Dev : NEXT_PUBLIC_API_URL=http://151.185.45.77:5002
#   Prod: NEXT_PUBLIC_API_URL=http://151.185.45.67:5002
NEXT_PUBLIC_API_URL=http://localhost:5002

# ── EasyHMS public API (patient booking portal) ──────────────────────────────
# Root of the EasyHMS API (NO trailing slash, NO /api prefix — paths are off root). This is the
# only required var — the public API works with zero further configuration.
EASYHMS_API_BASE_URL=
# Optional — the public API doesn't require a key, so this can stay blank. Only set it if this
# deployment's traffic should be identified/revocable separately from anonymous callers, via
# easyHMSAPI's tools/IssuePublicApiKey console tool (see easyHMSAPI/docs/OPS-ISSUE-PUBLIC-API-KEY.md).
# Keep this server-side only — do NOT prefix with NEXT_PUBLIC. For production,
# move it out of this committed file into .env.local or a real secret store.
EASYHMS_API_KEY=
# Header the API expects the key in. Adjust to match the backend (e.g. X-Api-Key).
EASYHMS_API_KEY_HEADER=X-Api-Key
