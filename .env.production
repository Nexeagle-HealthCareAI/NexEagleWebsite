NEXT_PUBLIC_API_URL=https://1hms-api.nexeagle.com/api/v1

# ── EasyHMS public API (patient booking portal) ──────────────────────────────
# Root of the EasyHMS API (NO trailing slash, NO /api prefix — paths are off root).
# Prod deployment (main branch -> Prod VM, port 5001 per
# easyHMSAPI/.github/workflows/deploy-api.yml's deploy-prod job).
EASYHMS_API_BASE_URL=https://1hms-api.nexeagle.com
# Optional — the public API doesn't require a key, so this can stay blank. Only set it (via the
# EASYHMS_PROD_API_KEY GitHub Actions secret, injected at deploy time — see deploy.yml) if this
# deployment's traffic should be identified/revocable separately from anonymous callers. Issued
# via easyHMSAPI's tools/IssuePublicApiKey console tool (see docs/OPS-ISSUE-PUBLIC-API-KEY.md).
EASYHMS_API_KEY=
EASYHMS_API_KEY_HEADER=X-Api-Key

# ── AI-assisted doctor search (app/api/search/parse) ─────────────────────────
# Optional — powers the "type/speak anything about symptoms" search fallback. Set via the
# ANTHROPIC_API_KEY GitHub Actions secret, injected at deploy time — see deploy.yml. Leave
# unset to disable — search just stays literal-keyword-only.
ANTHROPIC_API_KEY=
