# Port the relay API listens on
PORT=4000

# Comma-separated list of allowed browser origins (the website dev + prod URLs)
ALLOWED_ORIGIN=http://localhost:8080,http://localhost:5173

# Doctor data source toggle:
#   manual -> serve the curated list in src/data/doctors.json
#   onehms -> fetch the live list from the 1HMS API
DOCTOR_SOURCE=manual

# 1HMS integration (leave blank until the 1HMS API is available).
# When ONEHMS_API_URL is set, bookings are forwarded there and (if DOCTOR_SOURCE=onehms)
# doctors are fetched from there.
ONEHMS_API_URL=
ONEHMS_API_KEY=
